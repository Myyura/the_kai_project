{
  "name": "the-kai-project",
  "version": "0.0.0",
  "description": "Open-source Japanese graduate school entrance exam archive and study platform.",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "node scripts/generate-docusaurus-tags.js && node scripts/generate-site-stats.js && docusaurus start",
    "build": "node scripts/generate-docusaurus-tags.js && node scripts/validate-content-data.js && node scripts/generate-site-stats.js && docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "dev": "yarn start",
    "generate:universities": "node scripts/generate-universities.js",
    "generate:site-stats": "node scripts/generate-site-stats.js",
    "tags:generate": "node scripts/generate-docusaurus-tags.js",
    "tags:migrate": "node scripts/migrate-namespaced-tags.js",
    "content:validate": "node scripts/generate-docusaurus-tags.js --check && node scripts/validate-content-data.js",
    "tags:audit": "node scripts/audit-tags.js",
    "data:validate": "yarn content:validate && yarn api:validate",
    "review:format": "node scripts/review-format.js",
    "api:generate": "node scripts/generate-api-data.js",
    "api:validate": "node scripts/generate-api-data.js --validate",
    "api:sync": "node scripts/sync-api-data.js"
  },
  "dependencies": {
    "@docusaurus/core": "3.9.2",
    "@docusaurus/faster": "3.9.2",
    "@docusaurus/plugin-pwa": "3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@docusaurus/theme-mermaid": "3.9.2",
    "@easyops-cn/docusaurus-search-local": "^0.55.1",
    "@hcaptcha/react-hcaptcha": "^2.0.2",
    "@mdx-js/react": "^3.1.1",
    "@supabase/supabase-js": "^2.98.0",
    "@types/react": "^19.2.7",
    "clsx": "^2.1.1",
    "gray-matter": "4.0.3",
    "html-to-image": "^1.11.13",
    "markdown-it": "^14.1.1",
    "open-ask-ai": "^0.7.3",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0",
    "rehype-mathjax": "^7.1.0",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.9.2",
    "@docusaurus/types": "3.9.2",
    "baseline-browser-mapping": "^2.10.13"
  },
  "resolutions": {
    "@babel/plugin-transform-modules-systemjs": "7.29.4",
    "@rollup/pluginutils/picomatch": "4.0.4",
    "@xmldom/xmldom": "0.9.10",
    "**/express/path-to-regexp": "0.1.13",
    "brace-expansion": "2.0.3",
    "dompurify": "3.4.11",
    "express/path-to-regexp": "0.1.13",
    "fast-uri": "3.1.2",
    "filelist/minimatch": "5.1.8",
    "filelist/minimatch/brace-expansion": "2.0.3",
    "lodash": "4.18.1",
    "lodash-es": "4.18.1",
    "micromatch/picomatch": "2.3.2",
    "minimatch": "5.1.8",
    "node-forge": "1.4.0",
    "picomatch": "4.0.4",
    "rollup": "2.80.0",
    "serve-handler/minimatch": "3.1.4",
    "serve-handler/minimatch/brace-expansion": "1.1.13",
    "serialize-javascript": "7.0.6",
    "shell-quote": "1.8.4",
    "svgo": "3.3.3",
    "undici": "7.28.0",
    "webpack-dev-server/express/path-to-regexp": "0.1.13",
    "ws": "8.21.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20",
    "yarn": ">=1.22.0"
  }
}
