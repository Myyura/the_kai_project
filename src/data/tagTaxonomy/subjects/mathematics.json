{
  "id": "Mathematics",
  "subject": {
    "labelZh": "基础数学",
    "labelJa": "基礎数学",
    "labelEn": "Foundational Math",
    "descriptionZh": "微积分、线性代数、复分析、微分方程、傅里叶分析、数论与几何等基础数学内容。",
    "descriptionJa": "微積分、線形代数、複素解析、微分方程式、フーリエ解析、整数論、幾何などの基礎数学。",
    "descriptionEn": "Foundational mathematics such as calculus, linear algebra, complex analysis, differential equations, Fourier analysis, number theory, and geometry."
  },
