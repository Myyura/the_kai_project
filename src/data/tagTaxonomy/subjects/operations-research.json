{
  "id": "Operations-Research",
  "subject": {
    "labelZh": "运筹与优化",
    "labelJa": "オペレーションズ・リサーチ",
    "labelEn": "Operations Research",
    "descriptionZh": "优化基础、线性规划、凸优化、非线性优化、组合优化、元启发式、排队论、博弈论、库存管理与决策分析。",
    "descriptionJa": "最適化基礎、線形計画、凸最適化、非線形最適化、組合せ最適化、メタヒューリスティクス、待ち行列理論、ゲーム理論、在庫管理、意思決定分析。",
    "descriptionEn": "Optimization basics, linear, convex, nonlinear and combinatorial optimization, metaheuristics, queueing theory, game theory, inventory management, and decision analysis."
  },
  "subsubjects": {
    "Operations-Research.Optimization-Basics": {
      "subject": "Operations-Research",
      "labelZh": "优化基础",
      "labelJa": "最適化基礎",
      "labelEn": "Optimization Basics",
      "descriptionZh": "优化模型、参数化问题、值函数、罚函数与灵敏度分析等基础概念。",
      "descriptionJa": "最適化モデル、パラメトリック問題、価値関数、ペナルティ法、感度分析などの基礎概念。",
      "descriptionEn": "Foundational concepts including optimization models, parametric problems, value functions, penalty methods, and sensitivity analysis."
    },
    "Operations-Research.Linear-Programming": {
      "subject": "Operations-Research",
      "labelZh": "线性规划",
      "labelJa": "線形計画",
      "labelEn": "Linear Programming",
      "descriptionZh": "线性规划建模、对偶、单纯形法、运输问题、互补松弛与内点相关方法。",
      "descriptionJa": "線形計画モデリング、双対性、単体法、輸送問題、相補性、内点関連手法。",
      "descriptionEn": "Linear programming models, duality, simplex methods, transportation problems, complementarity, and related solution methods."
    },
    "Operations-Research.Convex-Optimization": {
      "subject": "Operations-Research",
      "labelZh": "凸优化",
      "labelJa": "凸最適化",
      "labelEn": "Convex Optimization",
      "descriptionZh": "凸集与凸函数、最优性条件、对偶几何、投影与一阶优化方法。",
      "descriptionJa": "凸集合と凸関数、最適性条件、双対幾何、射影、一階最適化法。",
      "descriptionEn": "Convex sets and functions, optimality conditions, dual geometry, projection, and first-order methods."
    },
    "Operations-Research.Nonlinear-Optimization": {
      "subject": "Operations-Research",
      "labelZh": "非线性优化",
      "labelJa": "非線形最適化",
      "labelEn": "Nonlinear Optimization",
      "descriptionZh": "二次规划、信赖域、正交约束及一般非线性优化问题。",
      "descriptionJa": "二次計画、信頼領域、直交制約、一般の非線形最適化問題。",
      "descriptionEn": "Quadratic programming, trust regions, orthogonality constraints, and general nonlinear optimization problems."
    },
    "Operations-Research.Combinatorial-Optimization": {
      "subject": "Operations-Research",
      "labelZh": "组合优化",
      "labelJa": "組合せ最適化",
      "labelEn": "Combinatorial Optimization",
      "descriptionZh": "最大流、匹配、最短路、最小生成树、集合覆盖、旅行商、分支定界与其他离散优化问题。",
      "descriptionJa": "最大フロー、マッチング、最短路、最小全域木、集合被覆、巡回セールスマン、分枝限定法などの離散最適化問題。",
      "descriptionEn": "Discrete optimization problems including maximum flow, matching, shortest paths, minimum spanning trees, set cover, traveling salesperson, and branch and bound."
    },
    "Operations-Research.Metaheuristics": {
      "subject": "Operations-Research",
      "labelZh": "元启发式优化",
      "labelJa": "メタヒューリスティクス",
      "labelEn": "Metaheuristics",
      "descriptionZh": "模拟退火等面向复杂搜索空间的随机化近似优化方法。",
      "descriptionJa": "焼きなまし法など、複雑な探索空間を扱う確率的近似最適化手法。",
      "descriptionEn": "Randomized approximate optimization methods for complex search spaces, including simulated annealing."
    },
    "Operations-Research.Queueing-Theory": {
      "subject": "Operations-Research",
      "labelZh": "排队论",
      "labelJa": "待ち行列理論",
      "labelEn": "Queueing Theory",
      "descriptionZh": "排队模型、到达过程、服务过程与系统性能。",
      "descriptionJa": "待ち行列モデル、到着過程、サービス過程、システム性能。",
      "descriptionEn": "Queueing models, arrival processes, service processes, and system performance."
    },
    "Operations-Research.Game-Theory": {
      "subject": "Operations-Research",
      "labelZh": "博弈论",
      "labelJa": "ゲーム理論",
      "labelEn": "Game Theory",
      "descriptionZh": "零和博弈、鞍点、纳什均衡与策略互动。",
      "descriptionJa": "ゼロ和ゲーム、鞍点、ナッシュ均衡、戦略的相互作用。",
      "descriptionEn": "Zero-sum games, saddle points, Nash equilibria, and strategic interaction."
    },
    "Operations-Research.Inventory-Management": {
      "subject": "Operations-Research",
      "labelZh": "库存管理",
      "labelJa": "在庫管理",
      "labelEn": "Inventory Management",
      "descriptionZh": "订货批量、补货策略、持有成本与数量折扣。",
      "descriptionJa": "発注量、補充方策、保管費用、数量割引。",
      "descriptionEn": "Order quantities, replenishment policies, holding costs, and quantity discounts."
    },
    "Operations-Research.Decision-Analysis": {
      "subject": "Operations-Research",
      "labelZh": "决策分析",
      "labelJa": "意思決定分析",
      "labelEn": "Decision Analysis",
      "descriptionZh": "多准则决策、层次分析法与判断一致性。",
      "descriptionJa": "多基準意思決定、階層分析法、判断の整合性。",
      "descriptionEn": "Multi-criteria decision making, analytic hierarchy process, and judgment consistency."
    }
  },
