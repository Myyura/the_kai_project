{
  "id": "Discrete-Mathematics",
  "subject": {
    "labelZh": "离散数学",
    "labelJa": "離散数学",
    "labelEn": "Discrete Mathematics",
    "descriptionZh": "组合计数、图论、图算法、集合论、数理逻辑与离散结构。",
    "descriptionJa": "組合せ計数、グラフ理論、グラフアルゴリズム、集合論、数理論理、離散構造。",
    "descriptionEn": "Combinatorial counting, graph theory, graph algorithms, set theory, mathematical logic, and discrete structures."
  },
  "subsubjects": {
