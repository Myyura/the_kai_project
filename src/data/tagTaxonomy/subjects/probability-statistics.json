{
  "id": "Probability-Statistics",
  "subject": {
    "labelZh": "概率与统计",
    "labelJa": "確率・統計",
    "labelEn": "Probability & Statistics",
    "descriptionZh": "概率基础、概率分布与渐近理论、随机过程，以及描述统计、统计推断、统计建模、贝叶斯统计和计算统计。",
    "descriptionJa": "確率基礎、確率分布と漸近理論、確率過程、記述統計、統計的推定と検定、統計モデリング、ベイズ統計、計算統計。",
    "descriptionEn": "Probability basics, distributions and asymptotics, stochastic processes, descriptive statistics, inference, statistical modeling, Bayesian statistics, and computational statistics."
  },
  "subsubjects": {
    "Probability-Statistics.Probability-Basics": {
      "subject": "Probability-Statistics",
      "labelZh": "概率基础",
      "labelJa": "確率基礎",
      "labelEn": "Probability Basics",
      "descriptionZh": "条件概率、Bayes 定理、期望与方差、联合分布、相关性、随机变量组合与经典概率问题。",
      "descriptionJa": "条件付き確率、ベイズの定理、期待値と分散、同時分布、相関、確率変数の組合せ、古典的確率問題。",
      "descriptionEn": "Conditional probability, Bayes theorem, expectation and variance, joint distributions, dependence, combinations of random variables, and classical probability problems."
    },
    "Probability-Statistics.Probability-Distributions-and-Asymptotics": {
      "subject": "Probability-Statistics",
      "labelZh": "概率分布与渐近理论",
      "labelJa": "確率分布と漸近理論",
      "labelEn": "Probability Distributions & Asymptotics",
      "descriptionZh": "常见离散与连续分布、分布变换、生成函数、大数定律、中心极限定理与分布逼近。",
      "descriptionJa": "代表的な離散・連続分布、分布変換、母関数、大数の法則、中心極限定理、分布近似。",
      "descriptionEn": "Common discrete and continuous distributions, distributional transforms, generating functions, laws of large numbers, central limit theorems, and distributional approximations."
    },
    "Probability-Statistics.Stochastic-Processes": {
      "subject": "Probability-Statistics",
      "labelZh": "随机过程",
      "labelJa": "確率過程",
      "labelEn": "Stochastic Processes",
      "descriptionZh": "马尔可夫链、随机游走、计数过程、等待时间、停止时间与其他带时间或状态结构的随机模型。",
      "descriptionJa": "マルコフ連鎖、ランダムウォーク、計数過程、待ち時間、停止時刻など、時間または状態構造をもつ確率モデル。",
      "descriptionEn": "Markov chains, random walks, counting processes, waiting times, stopping times, and other stochastic models with temporal or state structure."
    },
    "Probability-Statistics.Descriptive-Statistics-and-Sampling": {
      "subject": "Probability-Statistics",
      "labelZh": "描述统计与抽样",
      "labelJa": "記述統計と標本抽出",
      "labelEn": "Descriptive Statistics & Sampling",
      "descriptionZh": "测量尺度、集中趋势、分位数、样本统计量、标准误与抽样偏差。",
      "descriptionJa": "尺度水準、代表値、分位点、標本統計量、標準誤差、標本抽出バイアス。",
      "descriptionEn": "Measurement scales, location summaries, quantiles, sample statistics, standard errors, and sampling bias."
    },
    "Probability-Statistics.Estimation-and-Hypothesis-Testing": {
      "subject": "Probability-Statistics",
      "labelZh": "估计与假设检验",
      "labelJa": "推定と仮説検定",
      "labelEn": "Estimation & Hypothesis Testing",
      "descriptionZh": "点估计与区间估计、最大似然、估计量性质、显著性检验、多重比较、统计功效与样本量。",
      "descriptionJa": "点推定と区間推定、最尤法、推定量の性質、仮説検定、多重比較、検出力、標本サイズ。",
      "descriptionEn": "Point and interval estimation, maximum likelihood, estimator properties, significance testing, multiple comparisons, statistical power, and sample size."
    },
    "Probability-Statistics.Statistical-Modeling-and-Experimental-Design": {
      "subject": "Probability-Statistics",
      "labelZh": "统计建模与实验设计",
      "labelJa": "統計モデリングと実験計画",
      "labelEn": "Statistical Modeling & Experimental Design",
      "descriptionZh": "线性与多元模型、最小二乘、回归诊断、判别分析、方差分析与实验设计。",
      "descriptionJa": "線形・多変量モデル、最小二乗法、回帰診断、判別分析、分散分析、実験計画。",
      "descriptionEn": "Linear and multivariate models, least squares, regression diagnostics, discriminant analysis, analysis of variance, and experimental design."
    },
    "Probability-Statistics.Bayesian-Statistics": {
      "subject": "Probability-Statistics",
      "labelZh": "贝叶斯统计",
      "labelJa": "ベイズ統計",
      "labelEn": "Bayesian Statistics",
      "descriptionZh": "先验与后验、共轭模型、后验赔率、贝叶斯推断与模型选择。",
      "descriptionJa": "事前分布と事後分布、共役モデル、事後オッズ、ベイズ推論、モデル選択。",
      "descriptionEn": "Priors and posteriors, conjugate models, posterior odds, Bayesian inference, and model selection."
    },
    "Probability-Statistics.Computational-Statistics": {
      "subject": "Probability-Statistics",
      "labelZh": "计算统计",
      "labelJa": "計算統計",
      "labelEn": "Computational Statistics",
      "descriptionZh": "Bootstrap、Monte Carlo 积分、方差缩减与其他计算型统计方法。",
      "descriptionJa": "ブートストラップ、モンテカルロ積分、分散減少法などの計算統計手法。",
      "descriptionEn": "Bootstrap, Monte Carlo integration, variance reduction, and other computational statistical methods."
    }
  },
