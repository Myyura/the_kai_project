      "descriptionEn": "Quantum computing models, quantum algorithms, and computational complexity."
    },
    "Computer-Science.Information-Theory": {
      "subject": "Computer-Science",
      "labelZh": "信息论",
      "labelJa": "情報理論",
      "labelEn": "Information Theory",
      "descriptionZh": "熵、互信息、信源编码、信道容量与纠错编码。",
      "descriptionJa": "エントロピー、相互情報量、情報源符号化、通信路容量、誤り訂正符号。",
