    },
    "Computer-Science.Data-Structures": {
      "subject": "Computer-Science",
      "labelZh": "数据结构",
      "labelJa": "データ構造",
      "labelEn": "Data Structures",
      "descriptionZh": "树、堆、哈希表、链表、队列、栈、字典树与并查集等数据组织结构。",
      "descriptionJa": "木、ヒープ、ハッシュ表、連結リスト、キュー、スタック、トライ、素集合データ構造。",
      "descriptionEn": "Trees, heaps, hash tables, linked lists, queues, stacks, tries, and disjoint-set data structures."
    },
    "Computer-Science.Algorithm-Design": {
      "subject": "Computer-Science",
      "labelZh": "算法设计与分析",
      "labelJa": "アルゴリズム設計と解析",
      "labelEn": "Algorithm Design & Analysis",
      "descriptionZh": "复杂度、分治、贪心、回溯、排序、搜索、选择与通用算法设计方法。",
      "descriptionJa": "計算量、分割統治、貪欲法、バックトラッキング、整列、探索、選択、一般的な設計手法。",
      "descriptionEn": "Complexity, divide and conquer, greedy methods, backtracking, sorting, searching, selection, and general algorithm design."
    },
    "Computer-Science.Dynamic-Programming": {
      "subject": "Computer-Science",
      "labelZh": "动态规划",
      "labelJa": "動的計画法",
      "labelEn": "Dynamic Programming",
      "descriptionZh": "动态规划方法及背包、子集和、公共子序列、编辑距离等典型问题。",
      "descriptionJa": "動的計画法とナップサック、部分和、共通部分列、編集距離などの典型問題。",
      "descriptionEn": "Dynamic programming and canonical problems such as knapsack, subset sum, common subsequences, and edit distance."
    },
    "Computer-Science.String-Algorithms": {
      "subject": "Computer-Science",
      "labelZh": "字符串算法",
      "labelJa": "文字列アルゴリズム",
      "labelEn": "String Algorithms",
      "descriptionZh": "字符串匹配、模式搜索、回文与滑动窗口等算法。",
      "descriptionJa": "文字列照合、パターン探索、回文、スライディングウィンドウなどのアルゴリズム。",
      "descriptionEn": "String matching, pattern search, palindromes, sliding windows, and related algorithms."
    }
