{
  "id": "Computer-Science",
  "subject": {
    "labelZh": "计算机科学",
    "labelJa": "計算機科学",
    "labelEn": "Computer Science",
    "descriptionZh": "算法、数据结构、形式语言、系统、信息论与计算理论。",
    "descriptionJa": "アルゴリズム、データ構造、形式言語、システム、情報理論、計算理論。",
    "descriptionEn": "Algorithms, data structures, formal languages, systems, information theory, and theory of computation."
  },
